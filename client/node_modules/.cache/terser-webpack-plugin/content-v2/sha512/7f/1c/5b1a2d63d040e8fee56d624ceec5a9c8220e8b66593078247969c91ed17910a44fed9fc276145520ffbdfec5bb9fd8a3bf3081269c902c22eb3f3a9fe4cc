 12 }}>Traspasos</Link>\r\n    <Link to=\"/tactics\" style={{ color: 'white', marginRight: 12 }}>Tácticas</Link>\r\n    <Link to=\"/fixtures\" style={{ color: 'white', marginRight: 12 }}>Jornadas</Link>\r\n    <Link to=\"/table\" style={{ color: 'white' }}>Clasificación</Link>\r\n  </nav>\r\n);\r\n\r\nexport default NavBar;\r\n","import React from 'react';\n\nconst Dashboard: React.FC = () => {\n    return (\n        <div className=\"dashboard\">\n            <h1>Football Manager Dashboard</h1>\n            <p>Welcome to your football management dashboard!</p>\n            {/* Additional components and statistics can be added here */}\n        </div>\n    );\n};\n\nexport default Dashboard;","import React from 'react';\nimport Dashboard from '../components/Dashboard';\n\nconst ManagerDashboard: React.FC = () => {\n    return (\n        <div>\n            <h1>Manager Dashboard</h1>\n            <Dashboard />\n        </div>\n    );\n};\n\nexport default ManagerDashboard;","import React from 'react';\r\n\r\nconst TeamCard: React.FC<{ team: any }> = ({ team }) => (\r\n  <div style={{ border: '1px solid #ddd', padding: 12, borderRadius: 8, background: '#fff' }}>\r\n    <h3>{team.name}</h3>\r\n    <p>{team.players?.length ?? 0} jugadores</p>\r\n  </div>\r\n);\r\n\r\nexport default TeamCard;\r\n","import React, { useEffect, useState } from 'react';\r\nimport { Link } from 'react-router-dom';\r\nimport TeamCard from '../components/TeamCard';\r\n\r\ntype Player = { id: number; name: string; position: string; stats: any };\r\ntype Team = { id: number; name: string; players: Player[] };\r\n\r\nconst Teams: React.FC = () => {\r\n  const [teams, setTeams] = useState<Team[]>([]);\r\n\r\n  useEffect(() => {\r\n    fetch('/api/teams')\r\n      .then(res => res.json())\r\n      .then(setTeams)\r\n      .catch(() => setTeams([]));\r\n  }, []);\r\n\r\n  return (\r\n    <div>\r\n      <h2>Equipos</h2>\r\n      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))', gap: 12 }}>\r\n        {teams.map(t => (\r\n          <Link key={t.id} to={`/teams/${t.id}`} style={{ textDecoration: 'none' }}>\r\n            <TeamCard team={t} />\r\n          </Link>\r\n        ))}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Teams;\r\n","import React, { useEffect, useState } from 'react';\r\nimport { useParams } from 'react-router-dom';\r\n\r\ntype Player = { id: number; name: string; position: string; stats: any };\r\ntype Team = { id: number; name: string; players: Player[] };\r\n\r\nfunction simulateMatchLocal(teamA: Team, teamB: Team) {\r\n  const a = Math.floor(Math.random() * 5);\r\n  const b = Math.floor(Math.random() * 5);\r\n  if (a > b) return `${teamA.name} wins ${a} - ${b}`;\r\n  if (a < b) return `${teamB.name} wins ${b} - ${a}`;\r\n  return `Draw ${a} - ${b}`;\r\n}\r\n\r\nconst TeamDetail: React.FC = () => {\r\n  const { id } = useParams<{ id: string }>();\r\n  const [team, setTeam] = useState<Team | null>(null);\r\n  const [message, setMessage] = useState('');\r\n\r\n  useEffect(() => {\r\n    if (!id) return;\r\n    fetch(`/api/teams/${id}`)\r\n      .then(r => r.text())\r\n      .then(t => {\r\n        try {\r\n          const parsed = JSON.parse(t);\r\n          setTeam(parsed);\r\n        } catch {\r\n          // server returns plain text in current implementation\r\n          setTeam({ id: Number(id), name: t, players: [] });\r\n        }\r\n      })\r\n      .catch(() => setTeam(null));\r\n  }, [id]);\r\n\r\n  if (!team) return <div>Cargando equipo...</div>;\r\n\r\n  return (\r\n    <div>\r\n      <h2>{team.name}</h2>\r\n      <h3>Plantilla</h3>\r\n      <ul>\r\n        {team.players?.map(p => (\r\n          <li key={p.id}>{p.name} — {p.position}</li>\r\n        ))}\r\n      </ul>\r\n\r\n      <div style={{ marginTop: 20 }}>\r\n        <button onClick={() => setMessage(simulateMatchLocal(team, { id: 999, name: 'Rival FC', players: [] }))}>\r\n          Simular partido vs Rival FC\r\n        </button>\r\n        {message && <p style={{ marginTop: 12 }}>{message}</p>}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default TeamDetail;\r\n","import React, { useEffect, useState } from 'react';\r\nimport { useParams } from 'react-router-dom';\r\n\r\nconst PlayerDetail: React.FC = () => {\r\n  const { id } = useParams<{ id: string }>();\r\n  const [player, setPlayer] = useState<any>(null);\r\n\r\n  useEffect(() => {\r\n    // No player API yet; read from seeded data if available\r\n    fetch('/data/players.json')\r\n      .then(r => r.json())\r\n      .then((players: any[]) => setPlayer(players.find(p => String(p.id) === id)))\r\n      .catch(() => setPlayer(null));\r\n  }, [id]);\r\n\r\n  if (!player) return <div>Jugador no encontrado</div>;\r\n\r\n  return (\r\n    <div>\r\n      <h2>{player.name}</h2>\r\n      <p>Posición: {player.position}</p>\r\n      <h4>Estadísticas</h4>\r\n      <ul>\r\n        <li>Goles: {player.stats?.goals ?? 0}</li>\r\n        <li>Asistencias: {player.stats?.assists ?? 0}</li>\r\n        <li>Apariciones: {player.stats?.appearances ?? 0}</li>\r\n      </ul>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default PlayerDetail;\r\n","import React from 'react';\r\n\r\nconst Transfers: React.FC = () => (\r\n  <div>\r\n    <h2>Traspasos</h2>\r\n    <p>Listado de traspasos (implementación futura).</p>\r\n  </div>\r\n);\r\n\r\nexport default Transfers;\r\n","import React from 'react';\r\n\r\nconst Tactics: React.FC = () => (\r\n  <div>\r\n    <h2>Tácticas</h2>\r\n    <p>Configurador de formaciones y roles (implementación futura).</p>\r\n  </div>\r\n);\r\n\r\nexport default Tactics;\r\n","import React from 'react';\r\n\r\nconst Fixtures: React.FC = () => (\r\n  <div>\r\n    <h2>Jornadas</h2>\r\n    <p>Calendario de partidos (implementación futura).</p>\r\n  </div>\r\n);\r\n\r\nexport default Fixtures;\r\n","import React from 'react';\r\n\r\nconst LeagueTable: React.FC = () => (\r\n  <div>\r\n    <h2>Clasificación</h2>\r\n    <p>Tabla de posiciones (implementación futura).</p>\r\n  </div>\r\n);\r\n\r\nexport default LeagueTable;\r\n","import React from 'react';\r\nimport { BrowserRouter, Routes, Route } from 'react-router-dom';\r\nimport NavBar from './components/NavBar';\r\nimport ManagerDashboard from './pages/ManagerDashboard';\r\nimport Teams from './pages/Teams';\r\nimport TeamDetail from './pages/TeamDetail';\r\nimport PlayerDetail from './pages/PlayerDetail';\r\nimport Transfers from './pages/Transfers';\r\nimport Tactics from './pages/Tactics';\r\nimport Fixtures from './pages/Fixtures';\r\nimport LeagueTable from './pages/LeagueTable';\r\n\r\nconst App: React.FC = () => {\r\n  return (\r\n    <BrowserRouter>\r\n      <NavBar />\r\n      <main style={{ padding: 20 }}>\r\n        <Routes>\r\n          <Route path=\"/\" element={<ManagerDashboard />} />\r\n          <Route path=\"/teams\" element={<Teams />} />\r\n          <Route path=\"/teams/:id\" element={<TeamDetail />} />\r\n          <Route path=\"/player/:id\" element={<PlayerDetail />} />\r\n          <Route path=\"/transfers\" element={<Transfers />} />\r\n          <Route path=\"/tactics\" element={<Tactics />} />\r\n          <Route path=\"/fixtures\" element={<Fixtures />} />\r\n          <Route path=\"/table\" element={<LeagueTable />} />\r\n        </Routes>\r\n      </main>\r\n    </BrowserRouter>\r\n  );\r\n};\r\n\r\nexport default App;\r\n","import React from 'react';\nimport ReactDOM from 'react-dom';\nimport './styles/main.css';\nimport App from './App';\n\nReactDOM.render(<App />, document.getElementById('root'));\n"]}}